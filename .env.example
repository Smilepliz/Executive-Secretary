# Опционально: отправка запроса рецензенту через EmailJS (без открытия почтового клиента).
# Скопируйте в `.env.local`, заполните значения из https://www.emailjs.com/
# После настройки шаблона в панели EmailJS поля template должны включать:
#   to_email, subject, message, reviewer_name, article_title
#
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
